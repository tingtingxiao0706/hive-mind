{
  "name": "@ai-hivemind/core",
  "version": "0.3.0",
  "description": "AI Agent 按需技能加载引擎 - 兼容 SKILL.md 标准，基于 Vercel AI SDK，支持模型切换、工作区隔离、脚本执行",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "llm",
    "skill-md",
    "vercel-ai-sdk",
    "progressive-loading"
  ],
  "author": "tingtingxiao0706",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tingtingxiao0706/hive-mind.git"
  },
  "homepage": "https://tingtingxiao0706.github.io/hive-mind/",
  "bugs": {
    "url": "https://github.com/tingtingxiao0706/hive-mind/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "execa": "^9.5.2",
    "gray-matter": "^4.0.3",
    "lru-cache": "^11.0.2",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": ">=1.0.0",
    "@ai-sdk/google": ">=1.0.0",
    "@ai-sdk/openai": ">=1.0.0",
    "@skill-tools/core": "0.2.2",
    "@skill-tools/router": "0.2.2",
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@skill-tools/core": {
      "optional": true
    },
    "@skill-tools/router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/openai": "^1.2.0",
    "@skill-tools/core": "^0.2.2",
    "@skill-tools/router": "^0.2.2",
    "@types/node": "^25.5.0",
    "ai": "^4.1.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.5"
  }
}
